{
  "expo": {
    "name": "Gestion Chaussures",
    "slug": "chaussures-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chaussures-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0f172a",
      "package": "com.gestionchaussures.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Gestion Chaussures",
      "shortName": "Chaussures",
      "description": "Application de gestion de boutique de chaussures",
      "themeColor": "#4f46e5",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ac2d9606-bbcc-458c-94d4-099bfbee2367"
      }
    }
  }
}
